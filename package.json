{
  "name": "chatai",
  "displayName": "chatAi",
  "description": "Chat with your local AI model from VS Code.",
  "version": "0.0.1",
  "publisher": "local",
  "icon": "media/chatAi.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chatAi",
          "title": "chatAi",
          "icon": "media/chatAi.svg"
        }
      ]
    },
    "views": {
      "chatAi": [
        {
          "id": "chatAi.chat",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "chatAi.clearChat",
        "title": "chatAi: Clear Chat",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "chatAi.clearChat",
          "when": "view == chatAi.chat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "chatAi",
      "properties": {
        "chatAi.endpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the Ollama server."
        },
        "chatAi.model": {
          "type": "string",
          "default": "gemma4:31b",
          "description": "Default Ollama model selected on startup (must match a name from `ollama list`)."
        },
        "chatAi.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "gemma4:31b",
            "qwen3.6:35b"
          ],
          "description": "List of Ollama models offered in the chat view's model picker."
        },
        "chatAi.context.includeTree": {
          "type": "boolean",
          "default": true,
          "description": "Include the workspace file tree (paths only, no contents) in the system message."
        },
        "chatAi.context.includeOpenTabs": {
          "type": "boolean",
          "default": true,
          "description": "Include the full contents of every open tab in the system message."
        },
        "chatAi.numCtx": {
          "type": "number",
          "default": 32768,
          "description": "Ollama context window in tokens (num_ctx). Ollama's default is only 2048, which silently truncates project context."
        },
        "chatAi.context.maxBytes": {
          "type": "number",
          "default": 100000,
          "description": "Maximum bytes read per open-tab file. Files larger than this are truncated."
        },
        "chatAi.context.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/out/**",
            "**/build/**",
            "**/.next/**",
            "**/coverage/**",
            "**/*.min.js",
            "**/*.min.css",
            "**/package-lock.json",
            "**/yarn.lock",
            "**/pnpm-lock.yaml"
          ],
          "description": "Glob patterns excluded from the workspace file tree (in addition to VS Code's files.exclude)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}